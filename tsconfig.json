{
  "compilerOptions": {
      "allowSyntheticDefaultImports" : true,
      "module": "commonjs",
      "esModuleInterop": true,
      "target": "ES2022",
      "noImplicitAny": false,
      "moduleResolution": "node",
      "sourceMap": false, 
      "outDir": "dist",
      "baseUrl": ".",
      "paths": {
          "*": [
              "node_modules/*",
              "src/*"
          ]
      }, 
    "typeRoots": [
        "node_modules/@types", "./typings"
    ],
    
  },
  "exclude": [
    "dist",
    "node_modules",
    "src/ui"
],
  "include": [
    "src/**/*",
    "src/lib/*", 
  ]
}